# Function to reset the game
def reset_game():
    global rocket1, seed
    seed = np.random.randint(0, 250, 9)  # Generate new terrain
    rocket1 = Rocket(25, HEIGHT - 180, 100, 50, "red", 1, 0, 0, 0, 0, np.pi/2, 0)  # Reset rocket position

# Make walls
def draw_walls():
    left = pygame.draw.line(screen, "black", (0, 0), (0, HEIGHT), 10)
    right = pygame.draw.line(screen, "black", (WIDTH, 0), (WIDTH, HEIGHT), 10)
    top = pygame.draw.line(screen, "black", (0, 0), (WIDTH, 0), 10)
    bottom = pygame.draw.line(screen, "black", (0, HEIGHT), (WIDTH, HEIGHT), 10)
    walls = [left, right, top, bottom]
    return walls
#Make procedural envirement
def make_envirement(WIDTH, HEIGHT, seed):
    blocks = []
    # Create starting pad
    blocks.append(pygame.draw.rect(screen, "grey", (0, HEIGHT - 80, 100, 80)))
   
    # Create ending pad
    blocks.append(pygame.draw.rect(screen, "grey", (WIDTH - 100, HEIGHT - 80, 100, 80)))
    
    # Create procedural blocks
    for i in range(8):
        x_pos = 100 + i * 100
        block = pygame.draw.rect(screen, "green", (x_pos, HEIGHT - seed[i], 100, seed[i]))
        blocks.append(block)

    return blocks

