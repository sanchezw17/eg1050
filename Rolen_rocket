# Function to reset the game
def reset_game():
    global rocket1, seed
    seed = np.random.randint(0, 250, 9)  # Generate new terrain
    rocket1 = Rocket(25, HEIGHT - 180, 100, 50, "red", 1, 0, 0, 0, 0, np.pi/2, 0)  # Reset rocket position

# Make walls
def draw_walls():
    left = pygame.draw.line(screen, "black", (0, 0), (0, HEIGHT), 10)
    right = pygame.draw.line(screen, "black", (WIDTH, 0), (WIDTH, HEIGHT), 10)
    top = pygame.draw.line(screen, "black", (0, 0), (WIDTH, 0), 10)
    bottom = pygame.draw.line(screen, "black", (0, HEIGHT), (WIDTH, HEIGHT), 10)
    walls = [left, right, top, bottom]
    return walls

# Make procedural environment
def make_envirement(WIDTH, HEIGHT, seed):
    # Create starting pad
    pygame.draw.rect(screen, "darkgrey", (0, HEIGHT - 80, 100, 80) )
    block_start = pygame.Rect(0, HEIGHT - 80, 100, 80)
   
    # Create ending pad
    pygame.draw.rect(screen, "darkgrey", (WIDTH - 100, HEIGHT - 80, 100, 80) )
    block_end = pygame.Rect(WIDTH - 100, HEIGHT - 80, 100, 80)
    
    # Create block for each square, using random game variables
    block_2 = pygame.Rect(100, HEIGHT - seed[0], 100, seed[0])
    pygame.draw.rect(screen, "darkgreen", block_2)

    block_3 = pygame.Rect(200, HEIGHT - seed[1], 100, seed[1])
    pygame.draw.rect(screen, "darkgreen", block_3)
    
    block_4 = pygame.Rect(300, HEIGHT - seed[2], 100, seed[2])
    pygame.draw.rect(screen, "darkgreen", block_4)

    block_5 = pygame.Rect(400, HEIGHT - seed[3], 100, seed[3])
    pygame.draw.rect(screen, "darkgreen", block_5)

    block_6 = pygame.Rect(500, HEIGHT - seed[4], 100, seed[4])
    pygame.draw.rect(screen, "darkgreen", block_6)

    block_7 = pygame.Rect(600, HEIGHT - seed[5], 100, seed[5])
    pygame.draw.rect(screen, "darkgreen", block_7)

    block_8 = pygame.Rect(700, HEIGHT - seed[6], 100, seed[6])
    pygame.draw.rect(screen, "darkgreen", block_8)

    block_9 = pygame.Rect(800, HEIGHT - seed[7], 100, seed[7])
    pygame.draw.rect(screen, "darkgreen", block_9)

    blocks = [block_start, block_end, block_2, block_3, block_4, block_5, block_6, block_7, block_8, block_9]
    return blocks

# Make rocket for the game
rocket1 = Rocket(25, HEIGHT - 180 , 100, 50, "red", 1, 0, 0, 0, 0, np.pi/2, 0)

#load in background/ other images
background_image = pygame.image.load("backgroundimage.jpg")  # Replace with your background image path
background_image = pygame.transform.scale(background_image, (WIDTH, HEIGHT))  # Scale to fit screen
sun_image = pygame.image.load("GOATV6.png")  # Load the sun image
sun_image = pygame.transform.scale(sun_image, (200, 200))  # Scale the sun image
# Main Game loop
run = True
while run:
    timer.tick(fps)
    screen.blit(background_image, (0, 0))
    screen.blit(sun_image, (WIDTH - 200, 0))  
    walls = draw_walls()
    rocket1.draw()
    rocket1.update_forces()
    rocket1.update_acceleration()
    rocket1.check_collision()
    rocket1.update_speed()
    rocket1.update_position()
    rocket1.print_info()
    blocks = make_envirement(WIDTH, HEIGHT, seed)
    rocket1.check_collision_blocks(blocks)

    for event in pygame.event.get():
        if event.type == pygame.QUIT:
            run = False
        
        # Make the rocket move
        if event.type == pygame.KEYDOWN:
            keys = pygame.key.get_pressed()  # Get currently pressed keys
            if keys[pygame.K_w]:
                rocket1.thrust = THRUST
            if keys[pygame.K_s]:
                rocket1.thrust = -THRUST
            if keys[pygame.K_a]:
                rocket1.angle += np.radians(TURN_AMOUNT)
            if keys[pygame.K_d]:
                rocket1.angle -= np.radians(TURN_AMOUNT)

        if event.type == pygame.KEYUP:  
            if event.key in (pygame.K_w, pygame.K_s):  
                    rocket1.thrust = 0  # Stop thrust when releasing keys

    pygame.display.flip()

pygame.quit()